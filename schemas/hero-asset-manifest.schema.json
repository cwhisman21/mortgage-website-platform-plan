{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://snapmortgage.com/schemas/hero-asset-manifest.schema.json",
  "title": "HeroAssetManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "status",
    "locality_set_audit",
    "locality_candidate_pools",
    "page_family_set_audit",
    "page_family_candidate_pools",
    "entries"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "../schemas/hero-asset-manifest.schema.json"
    },
    "schema_version": { "type": "string", "const": "1.3.0" },
    "status": { "type": "string", "const": "draft" },
    "locality_set_audit": { "$ref": "#/$defs/locality_set_audit" },
    "locality_candidate_pools": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/locality_candidate_pool" }
    },
    "page_family_set_audit": { "$ref": "#/$defs/page_family_set_audit" },
    "page_family_candidate_pools": {
      "type": "array",
      "minItems": 13,
      "maxItems": 13,
      "items": { "$ref": "#/$defs/page_family_candidate_pool" }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/manifest_entry" }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "locality_set_audit": {
            "properties": { "manual_editorial_result": { "const": "failed" } },
            "required": ["manual_editorial_result"]
          }
        },
        "required": ["locality_set_audit"]
      },
      "then": {
        "properties": {
          "locality_candidate_pools": {
            "items": {
              "properties": { "selection_outcome": { "const": "unresolved" } },
              "required": ["selection_outcome"]
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "selection_thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maximum_skyline_count",
        "maximum_water_count",
        "minimum_lived_behavior_count"
      ],
      "properties": {
        "maximum_skyline_count": { "type": "integer", "minimum": 0 },
        "maximum_water_count": { "type": "integer", "minimum": 0 },
        "minimum_lived_behavior_count": { "type": "integer", "minimum": 1 }
      }
    },
    "locality_set_audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope",
        "review_method",
        "manual_editorial_result",
        "selection_thresholds",
        "observed_nominated_skyline_count",
        "observed_nominated_water_count",
        "observed_nominated_lived_behavior_count",
        "failure_reasons"
      ],
      "properties": {
        "scope": { "type": "string", "const": "prototype_locality_candidate_set" },
        "review_method": { "type": "string", "const": "manual_editorial_audit" },
        "manual_editorial_result": {
          "type": "string",
          "enum": ["passed", "failed"]
        },
        "selection_thresholds": { "$ref": "#/$defs/selection_thresholds" },
        "observed_nominated_skyline_count": { "type": "integer", "minimum": 0 },
        "observed_nominated_water_count": { "type": "integer", "minimum": 0 },
        "observed_nominated_lived_behavior_count": {
          "type": "integer",
          "minimum": 0
        },
        "failure_reasons": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "visible_locality_signal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["signal_type", "evidence"],
      "properties": {
        "signal_type": {
          "type": "string",
          "enum": [
            "regional_architecture",
            "terrain_or_ecology",
            "street_or_neighborhood_form",
            "lived_behavior",
            "civic_cultural_infrastructure",
            "season_or_light"
          ]
        },
        "evidence": { "type": "string", "minLength": 1 }
      }
    },
    "visual_motif": {
      "type": "string",
      "enum": [
        "skyline",
        "water",
        "landscape",
        "park",
        "neighborhood",
        "housing",
        "civic_infrastructure",
        "landmark",
        "lived_behavior"
      ]
    },
    "locality_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["geography_claim", "visible_signals", "signal_count"],
      "properties": {
        "geography_claim": { "type": "string", "minLength": 1 },
        "visible_signals": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "items": { "$ref": "#/$defs/visible_locality_signal" }
        },
        "signal_count": { "type": "integer", "minimum": 1, "maximum": 6 }
      }
    },
    "source_dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 }
      }
    },
    "locality_asset_candidate": {
      "type": "object",
      "additionalProperties": false,
      "x-lifecycle-order": [
        "research_candidate",
        "nominated",
        "acquired_rights_complete",
        "selected",
        "reviewed_approved"
      ],
      "required": [
        "candidate_id",
        "repository_asset_id",
        "asset_type",
        "source_tier",
        "claimed_geography",
        "asset_page_url",
        "source_repository",
        "creator_or_agency",
        "displayed_caption",
        "license_name",
        "license_url",
        "attribution_label",
        "source_accessed_at",
        "source_dimensions",
        "release_status",
        "risk_notes",
        "rights_eligibility",
        "editorial_locality_eligibility",
        "candidate_disposition",
        "lifecycle_stage",
        "visual_motifs",
        "locality_evidence",
        "selection_rationale",
        "acquisition_status",
        "rights_review_status",
        "editorial_review_status",
        "publishing_status"
      ],
      "properties": {
        "candidate_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "repository_asset_id": { "type": "string", "minLength": 1 },
        "asset_type": { "type": "string", "const": "photograph" },
        "source_tier": {
          "type": "string",
          "enum": ["exact_geography", "verified_subregion"]
        },
        "claimed_geography": { "type": "string", "minLength": 1 },
        "asset_page_url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "source_repository": { "type": "string", "minLength": 1 },
        "creator_or_agency": { "type": "string", "minLength": 1 },
        "displayed_caption": { "type": "string", "minLength": 1 },
        "license_name": { "type": "string", "minLength": 1 },
        "license_url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "attribution_label": { "type": "string", "minLength": 1 },
        "source_accessed_at": { "type": "string", "format": "date" },
        "source_dimensions": { "$ref": "#/$defs/source_dimensions" },
        "release_status": {
          "type": "string",
          "enum": ["not_applicable", "verified", "not_verified", "required"]
        },
        "risk_notes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "rights_eligibility": {
          "type": "string",
          "enum": ["eligible_for_rights_review", "blocked_pending_clearance"]
        },
        "editorial_locality_eligibility": {
          "type": "string",
          "enum": ["eligible_for_nomination", "ineligible"]
        },
        "editorial_locality_ineligibility_reasons": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "candidate_disposition": {
          "type": "string",
          "enum": ["research_candidate", "nominated", "selected", "blocked"]
        },
        "lifecycle_stage": {
          "type": "string",
          "enum": [
            "research_candidate",
            "nominated",
            "acquired_rights_complete",
            "selected",
            "reviewed_approved"
          ]
        },
        "visual_motifs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/visual_motif" }
        },
        "locality_evidence": { "$ref": "#/$defs/locality_evidence" },
        "selection_rationale": { "type": "string", "minLength": 1 },
        "acquisition_status": {
          "type": "string",
          "enum": ["not_acquired", "acquired"]
        },
        "rights_review_status": {
          "type": "string",
          "enum": ["not_started", "in_progress", "complete"]
        },
        "editorial_review_status": {
          "type": "string",
          "enum": ["not_started", "in_progress", "approved"]
        },
        "publishing_status": {
          "type": "string",
          "enum": ["prohibited", "authorized"]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "lifecycle_stage": { "const": "research_candidate" } },
            "required": ["lifecycle_stage"]
          },
          "then": {
            "properties": {
              "candidate_disposition": { "enum": ["research_candidate", "blocked"] },
              "acquisition_status": { "const": "not_acquired" },
              "publishing_status": { "const": "prohibited" }
            }
          }
        },
        {
          "if": {
            "properties": { "lifecycle_stage": { "const": "nominated" } },
            "required": ["lifecycle_stage"]
          },
          "then": {
            "properties": {
              "candidate_disposition": { "const": "nominated" },
              "publishing_status": { "const": "prohibited" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "lifecycle_stage": { "const": "acquired_rights_complete" }
            },
            "required": ["lifecycle_stage"]
          },
          "then": {
            "properties": {
              "candidate_disposition": { "const": "nominated" },
              "acquisition_status": { "const": "acquired" },
              "rights_review_status": { "const": "complete" },
              "publishing_status": { "const": "prohibited" }
            }
          }
        },
        {
          "if": {
            "properties": { "lifecycle_stage": { "const": "selected" } },
            "required": ["lifecycle_stage"]
          },
          "then": {
            "properties": {
              "candidate_disposition": { "const": "selected" },
              "acquisition_status": { "const": "acquired" },
              "rights_review_status": { "const": "complete" },
              "publishing_status": { "const": "prohibited" }
            }
          }
        },
        {
          "if": {
            "properties": { "lifecycle_stage": { "const": "reviewed_approved" } },
            "required": ["lifecycle_stage"]
          },
          "then": {
            "properties": {
              "candidate_disposition": { "const": "selected" },
              "acquisition_status": { "const": "acquired" },
              "rights_review_status": { "const": "complete" },
              "editorial_review_status": { "const": "approved" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "release_status": { "enum": ["not_verified", "required"] }
            },
            "required": ["release_status"]
          },
          "then": {
            "properties": {
              "rights_eligibility": { "const": "blocked_pending_clearance" },
              "candidate_disposition": { "const": "blocked" },
              "publishing_status": { "const": "prohibited" }
            }
          }
        },
        {
          "if": {
            "properties": { "editorial_locality_eligibility": { "const": "ineligible" } },
            "required": ["editorial_locality_eligibility"]
          },
          "then": {
            "required": ["editorial_locality_ineligibility_reasons"],
            "properties": {
              "candidate_disposition": {
                "enum": ["research_candidate", "blocked"]
              },
              "publishing_status": { "const": "prohibited" }
            }
          },
          "else": {
            "not": { "required": ["editorial_locality_ineligibility_reasons"] }
          }
        },
        {
          "if": {
            "properties": { "candidate_disposition": { "const": "selected" } },
            "required": ["candidate_disposition"]
          },
          "then": {
            "properties": {
              "rights_eligibility": { "const": "eligible_for_rights_review" },
              "editorial_locality_eligibility": { "const": "eligible_for_nomination" },
              "acquisition_status": { "const": "acquired" },
              "rights_review_status": { "const": "complete" },
              "publishing_status": { "const": "prohibited" }
            }
          }
        },
        {
          "if": {
            "properties": { "publishing_status": { "const": "authorized" } },
            "required": ["publishing_status"]
          },
          "then": {
            "properties": {
              "candidate_disposition": { "const": "selected" },
              "lifecycle_stage": { "const": "reviewed_approved" },
              "acquisition_status": { "const": "acquired" },
              "rights_review_status": { "const": "complete" },
              "editorial_review_status": { "const": "approved" }
            }
          }
        }
      ]
    },
    "locality_candidate_pool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route",
        "target_geography",
        "geography_kind",
        "selection_outcome",
        "publishing_status",
        "next_sourcing_step",
        "candidates"
      ],
      "properties": {
        "route": { "type": "string", "pattern": "^/[a-z0-9/-]+$" },
        "target_geography": { "type": "string", "minLength": 1 },
        "geography_kind": { "type": "string", "enum": ["state", "city"] },
        "selection_outcome": {
          "type": "string",
          "enum": ["candidate_selected", "unresolved"]
        },
        "selected_candidate_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "nominated_candidate_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "unresolved_reason": { "type": "string", "minLength": 1 },
        "publishing_status": { "type": "string", "const": "prohibited" },
        "next_sourcing_step": {
          "type": "string",
          "const": "commission_lived_behavior_or_approved_tier_3_generation"
        },
        "candidates": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/locality_asset_candidate" }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "selection_outcome": { "const": "candidate_selected" } },
            "required": ["selection_outcome"]
          },
          "then": {
            "required": ["selected_candidate_id"],
            "not": { "required": ["unresolved_reason"] },
            "properties": {
              "candidates": {
                "contains": {
                  "properties": { "candidate_disposition": { "const": "selected" } },
                  "required": ["candidate_disposition"]
                },
                "minContains": 1,
                "maxContains": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": { "selection_outcome": { "const": "unresolved" } },
            "required": ["selection_outcome"]
          },
          "then": {
            "required": ["unresolved_reason"],
            "not": { "required": ["selected_candidate_id"] },
            "properties": {
              "candidates": {
                "not": {
                  "contains": {
                    "properties": { "candidate_disposition": { "const": "selected" } },
                    "required": ["candidate_disposition"]
                  }
                }
              }
            }
          }
        },
        {
          "if": { "required": ["nominated_candidate_id"] },
          "then": {
            "properties": {
              "candidates": {
                "contains": {
                  "properties": { "candidate_disposition": { "const": "nominated" } },
                  "required": ["candidate_disposition"]
                },
                "minContains": 1,
                "maxContains": 1
              }
            }
          }
        }
      ]
    },
    "page_family_set_audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope",
        "review_method",
        "manual_editorial_result",
        "audited_candidate_count",
        "prohibited_cliches",
        "observed_prohibited_cliche_count",
        "candidate_ids_with_prohibited_cliches",
        "observed_duplicate_asset_url_count",
        "duplicate_asset_urls",
        "repeated_creators",
        "repetition_findings",
        "decision"
      ],
      "properties": {
        "scope": { "type": "string", "const": "non_location_page_family_candidate_set" },
        "review_method": { "type": "string", "const": "manual_editorial_audit" },
        "manual_editorial_result": { "type": "string", "const": "failed" },
        "audited_candidate_count": { "type": "integer", "const": 19 },
        "prohibited_cliches": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "key_handoff",
              "cash_pile",
              "handshake",
              "generic_laptop",
              "anonymous_boardroom"
            ]
          }
        },
        "observed_prohibited_cliche_count": { "type": "integer", "const": 0 },
        "candidate_ids_with_prohibited_cliches": {
          "type": "array",
          "maxItems": 0
        },
        "observed_duplicate_asset_url_count": { "type": "integer", "const": 0 },
        "duplicate_asset_urls": {
          "type": "array",
          "maxItems": 0
        },
        "repeated_creators": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["Pavel Danilyuk", "RDNE Stock project"]
          }
        },
        "repetition_findings": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "decision": { "type": "string", "const": "no_selection" }
      }
    },
    "page_family_asset_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "asset_origin",
        "asset_page_url",
        "source_repository",
        "creator_or_agency",
        "displayed_caption",
        "source_accessed_at",
        "attribution_label",
        "release_assessment",
        "release_property_trademark_risks",
        "page_relevance",
        "crop_risks",
        "assigned_hero_variant",
        "composition_fit",
        "composition_fit_notes",
        "prohibited_cliches_detected",
        "candidate_disposition",
        "lifecycle_stage",
        "acquisition_status",
        "rights_review_status",
        "editorial_review_status",
        "crop_review_status",
        "publishing_status"
      ],
      "properties": {
        "candidate_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "asset_origin": { "type": "string", "const": "stock" },
        "asset_page_url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "source_repository": { "type": "string", "enum": ["Pexels", "Wikimedia Commons"] },
        "creator_or_agency": { "type": "string", "minLength": 1 },
        "displayed_caption": { "type": "string", "minLength": 1 },
        "license_name": { "type": "string", "minLength": 1 },
        "license_url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "rights_basis_type": { "type": "string", "enum": ["license", "public_domain_mark", "terms_of_use", "disputed"] },
        "rights_basis_name": { "type": "string", "minLength": 1 },
        "rights_basis_url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "original_source_url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "controlling_terms_url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "commons_public_domain_mark_url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "commons_public_domain_assertion_status": { "type": "string", "const": "disputed" },
        "rights_eligibility": { "type": "string", "const": "blocked_pending_clearance" },
        "conditional_attribution_and_use_restrictions": {
          "type": "array",
          "minItems": 5,
          "items": { "type": "string", "minLength": 1 }
        },
        "source_accessed_at": { "type": "string", "format": "date" },
        "attribution_label": { "type": "string", "minLength": 1 },
        "release_assessment": { "type": "string", "const": "pending_acquisition_review" },
        "release_property_trademark_risks": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "page_relevance": { "type": "string", "minLength": 1 },
        "crop_risks": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "assigned_hero_variant": {
          "type": "string",
          "enum": [
            "tall_diagonal_image_slab",
            "wide_panoramic_band",
            "rotated_architectural_window",
            "circular_criteria_or_brand_field",
            "layered_editorial_collage",
            "media_left_editorial_panel",
            "evidence_or_report_strip",
            "horizon_composition",
            "stacked_planning_panels"
          ]
        },
        "composition_fit": {
          "type": "string",
          "enum": ["supports_assigned_variant", "component_for_assigned_composition"]
        },
        "composition_fit_notes": { "type": "string", "minLength": 1 },
        "editorial_evidence_role": {
          "type": "string",
          "const": "current_housing_market_evidence"
        },
        "seller_journey_phase": {
          "type": "string",
          "enum": ["current_home", "sell_and_buy_transition", "future_home_tradeoffs"]
        },
        "prohibited_cliches_detected": { "type": "array", "maxItems": 0 },
        "candidate_disposition": { "type": "string", "const": "nominated" },
        "lifecycle_stage": { "type": "string", "const": "nominated" },
        "acquisition_status": { "type": "string", "const": "not_acquired" },
        "rights_review_status": { "type": "string", "const": "not_started" },
        "editorial_review_status": { "type": "string", "const": "not_started" },
        "crop_review_status": { "type": "string", "const": "not_started" },
        "publishing_status": { "type": "string", "const": "prohibited" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "rights_basis_type": { "const": "disputed" } },
            "required": ["rights_basis_type"]
          },
          "then": {
            "required": ["rights_basis_name", "rights_basis_url", "original_source_url", "controlling_terms_url", "commons_public_domain_mark_url", "commons_public_domain_assertion_status", "rights_eligibility", "conditional_attribution_and_use_restrictions"],
            "not": {
              "anyOf": [
                { "required": ["license_name"] },
                { "required": ["license_url"] }
              ]
            }
          },
          "else": { "required": ["license_name", "license_url"] }
        }
      ]
    },
    "internal_asset_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asset_origin_requirement",
        "required_subject",
        "substitute_prohibition",
        "acceptance_requirements"
      ],
      "properties": {
        "asset_origin_requirement": { "type": "string", "const": "internal" },
        "required_subject": { "type": "string", "minLength": 1 },
        "substitute_prohibition": { "type": "string", "minLength": 1 },
        "acceptance_requirements": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "structured_composition_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["photo_required", "treatment", "acceptance_requirements"],
      "properties": {
        "photo_required": { "type": "boolean", "const": false },
        "treatment": { "type": "string", "minLength": 1 },
        "acceptance_requirements": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "page_family_candidate_pool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route",
        "page_type",
        "hero_variant",
        "source_strategy",
        "selection_outcome",
        "unresolved_reason",
        "publishing_status",
        "next_sourcing_step",
        "candidates"
      ],
      "properties": {
        "route": { "type": "string", "pattern": "^/[a-z0-9/-]+$" },
        "page_type": {
          "type": "string",
          "enum": [
            "buy",
            "refinance",
            "home_equity",
            "loan_product",
            "learning_center",
            "topic_hub",
            "article",
            "loan_officer",
            "branch",
            "company",
            "search_directory",
            "prequalification",
            "seller_move_up"
          ]
        },
        "hero_variant": {
          "type": "string",
          "enum": [
            "tall_diagonal_image_slab",
            "wide_panoramic_band",
            "rotated_architectural_window",
            "circular_criteria_or_brand_field",
            "layered_editorial_collage",
            "media_left_editorial_panel",
            "evidence_or_report_strip",
            "vertical_human_portrait",
            "structured_search_or_planning_interface",
            "horizon_composition",
            "stacked_planning_panels"
          ]
        },
        "source_strategy": {
          "type": "string",
          "enum": [
            "external_stock_candidates",
            "internal_only",
            "internal_preferred",
            "non_photographic"
          ]
        },
        "selection_outcome": { "type": "string", "const": "unresolved" },
        "unresolved_reason": { "type": "string", "minLength": 1 },
        "publishing_status": { "type": "string", "const": "prohibited" },
        "next_sourcing_step": {
          "type": "string",
          "enum": [
            "acquire_and_review_nominees_or_commission",
            "obtain_actual_internal_asset",
            "commission_actual_internal_operating_photography",
            "design_and_review_structured_non_photographic_treatment"
          ]
        },
        "candidates": {
          "type": "array",
          "items": { "$ref": "#/$defs/page_family_asset_candidate" }
        },
        "internal_asset_requirement": { "$ref": "#/$defs/internal_asset_requirement" },
        "structured_composition_requirement": {
          "$ref": "#/$defs/structured_composition_requirement"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "source_strategy": { "const": "external_stock_candidates" } },
            "required": ["source_strategy"]
          },
          "then": {
            "properties": { "candidates": { "minItems": 2 } },
            "not": {
              "anyOf": [
                { "required": ["internal_asset_requirement"] },
                { "required": ["structured_composition_requirement"] }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "source_strategy": { "enum": ["internal_only", "internal_preferred"] }
            },
            "required": ["source_strategy"]
          },
          "then": {
            "required": ["internal_asset_requirement"],
            "properties": { "candidates": { "maxItems": 0 } },
            "not": { "required": ["structured_composition_requirement"] }
          }
        },
        {
          "if": {
            "properties": { "source_strategy": { "const": "non_photographic" } },
            "required": ["source_strategy"]
          },
          "then": {
            "required": ["structured_composition_requirement"],
            "properties": { "candidates": { "maxItems": 0 } },
            "not": { "required": ["internal_asset_requirement"] }
          }
        }
      ]
    },
    "manifest_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["route", "coverage_kind", "asset_selection_status", "hero"],
      "properties": {
        "route": { "type": "string", "pattern": "^/[a-z0-9/-]+$" },
        "coverage_kind": {
          "type": "string",
          "enum": ["prototype_route", "representative_page_family"]
        },
        "asset_selection_status": { "type": "string", "const": "unselected" },
        "hero": { "$ref": "hero-image.schema.json" }
      }
    }
  }
}
